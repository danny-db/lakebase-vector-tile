# Lakebase connection credentials
# Copy to .env and fill in values for local development

LAKEBASE_HOST=<your-lakebase-endpoint>.database.us-east-1.cloud.databricks.com
LAKEBASE_PORT=5432
LAKEBASE_DATABASE=databricks_postgres
LAKEBASE_SCHEMA=geo
LAKEBASE_USER=<your-postgres-role>
LAKEBASE_PASSWORD=<your-password>
